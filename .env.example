# OpenClaw Dashboard Environment Variables
# Copy this file to .env and fill in your values

# Dashboard port (optional, default: 18790)
DASHBOARD_PORT=18790

# OpenClaw Gateway URL (optional, default: http://127.0.0.1:18789)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Node environment (optional, default: production)
NODE_ENV=production
